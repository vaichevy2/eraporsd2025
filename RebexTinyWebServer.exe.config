<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Server configuration -->
    <add key="Port" value="80" />
    <add key="BindAddress" value="127.0.0.1" />
    <add key="RootPath" value="." />
    <add key="DefaultDocument" value="rapor.html" />

    <!-- CORS settings for API access -->
    <add key="AllowCors" value="true" />
    <add key="CorsOrigins" value="http://localhost:1180" />

    <!-- Logging -->
    <add key="LogFile" value="server.log" />
    <add key="LogLevel" value="Info" />

    <!-- Security -->
    <add key="EnableDirectoryListing" value="false" />
    <add key="EnableFileUpload" value="true" />
    <add key="MaxFileSize" value="10485760" /> <!-- 10MB -->

    <!-- API Proxy settings -->
    <add key="ProxyEnabled" value="true" />
    <add key="ProxyRules" value="/api/*=http://localhost:1180/api/*" />
  </appSettings>
</configuration>
